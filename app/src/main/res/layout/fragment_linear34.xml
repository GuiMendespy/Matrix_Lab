<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.reflow.Linear34">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Polinômio Minimal e Espaços com Produto Interno"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#005088"
            android:paddingBottom="8dp" />

        <View
            android:layout_width="100dp"
            android:layout_height="3dp"
            android:background="#005088"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Polinômio Minimal"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:justificationMode="inter_word"
            android:text="O polinômio minimal \(m(x)\) de uma matriz \(A\) é o polinômio de menor grau, com coeficiente líder unitário, que anula a matriz." />

        <WebView
            android:id="@+id/math_polinomio_minimal"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@android:color/transparent" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\n2. Produto Interno e Norma"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Dois vetores são ortogonais se o seu produto interno é nulo. A norma define o 'comprimento' do vetor." />

        <WebView
            android:id="@+id/math_norma_angulo"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@android:color/transparent" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/unidade3_40" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/unidade3_41" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\n3. Ortonormalização de Gram-Schmidt"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#005088" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Processo para obter uma base ortonormal a partir de uma base qualquer:" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/unidade3_43" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/unidade3_48" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\n4. Produto Interno Complexo"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Nos espaços complexos (\(\mathbb{C}^n\)), a simetria é substituída pela simetria conjugada:" />

        <WebView
            android:id="@+id/math_complexo"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@android:color/transparent" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/unidade3_49" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/unidade3_50" />

        <View
            android:layout_width="match_parent"
            android:layout_height="80dp" />

    </LinearLayout>
</ScrollView>