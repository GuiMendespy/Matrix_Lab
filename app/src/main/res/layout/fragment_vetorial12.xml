<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.reflow.Vetorial12">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/text16_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_vetorial"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:paddingBottom="12dp" />

        <WebView
            android:id="@+id/math_v1_v2"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@android:color/transparent" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/content_figura_1"
            android:src="@drawable/exemplo11" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/desc_vetores_base"
            android:textSize="16sp"
            android:justificationMode="inter_word" />

        <WebView
            android:id="@+id/math_list_equations"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:background="@android:color/transparent" />

        <TextView
            android:id="@+id/text17_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/desc_combinacao_geral"
            android:textSize="16sp"
            android:justificationMode="inter_word" />

        <WebView
            android:id="@+id/math_comb_linear"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@android:color/transparent" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/desc_teoria_base"
            android:textSize="16sp"
            android:justificationMode="inter_word" />

        <WebView
            android:id="@+id/math_canonica"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@android:color/transparent" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/content_figura_2"
            android:src="@drawable/exemplo12" />

        <WebView
            android:id="@+id/math_final"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@android:color/transparent" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/content_figura_3"
            android:src="@drawable/exemplo13" />

    </LinearLayout>
</ScrollView>