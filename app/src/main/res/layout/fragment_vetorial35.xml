<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.reflow.Vetorial35">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Superfícies Quádricas"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#005088"
            android:paddingBottom="8dp" />

        <View
            android:layout_width="100dp"
            android:layout_height="3dp"
            android:background="#005088"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:justificationMode="inter_word"
            android:text="Uma superfície quádrica é o lugar geométrico dos pontos P(x, y, z) cujas coordenadas satisfazem a equação geral do 2° grau em três variáveis:" />

        <WebView
            android:id="@+id/math_quadrica_geral"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@android:color/transparent" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/unidade3_12" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:justificationMode="inter_word"
            android:paddingTop="12dp"
            android:text="A interseção de uma superfície com um plano é chamada de traço. Se seccionarmos uma quádrica por planos paralelos aos planos coordenados, a curva resultante será sempre uma cônica." />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:layout_marginTop="12dp"
            android:src="@drawable/unidade3_13" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:justificationMode="inter_word"
            android:paddingTop="12dp"
            android:text="Existem casos onde a equação pode representar pontos, retas ou o conjunto vazio, conhecidos como quádricas degeneradas. Focaremos nas formas canônicas centradas:" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\n1. Elipsoide"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <WebView
            android:id="@+id/math_elipsoide"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@android:color/transparent" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\n2. Hiperboloides (Uma e Duas Folhas)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <WebView
            android:id="@+id/math_hiperboloides"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@android:color/transparent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="80dp" />

    </LinearLayout>
</ScrollView>