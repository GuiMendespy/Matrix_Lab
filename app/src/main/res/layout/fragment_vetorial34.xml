<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.reflow.Vetorial34">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A PARÁBOLA"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:justificationMode="inter_word"
            android:text="Parábola é o conjunto de todos os pontos de um plano que são equidistantes de um ponto fixo F (foco) e de uma reta fixa d (diretriz)." />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:layout_marginTop="12dp"
            android:src="@drawable/unidade3_9" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:justificationMode="inter_word"
            android:paddingTop="8dp"
            android:text="Um ponto P qualquer pertence à parábola se, e somente se, a distância de P até F for igual à distância de P até a reta d:" />

        <WebView
            android:id="@+id/math_condicao_parabola"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@android:color/transparent" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\n1. Concavidade voltada para o eixo Ox"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <WebView
            android:id="@+id/math_parabola_ox"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:background="@android:color/transparent" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/unidade3_10" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\n2. Concavidade voltada para o eixo Oy"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <WebView
            android:id="@+id/math_parabola_oy"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:background="@android:color/transparent" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/unidade3_11" />

        <View
            android:layout_width="match_parent"
            android:layout_height="80dp" />

    </LinearLayout>
</ScrollView>