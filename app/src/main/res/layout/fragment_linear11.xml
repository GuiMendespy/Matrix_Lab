<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Espaços Vetoriais"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#005088"
            android:paddingBottom="8dp" />

        <View
            android:layout_width="100dp"
            android:layout_height="3dp"
            android:background="#005088"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:justificationMode="inter_word"
            android:text="O conjunto ℝⁿ é interpretado geometricamente como o espaço n-dimensional. Um elemento desse conjunto pode ser visto como um ponto ou como um vetor." />

        <WebView
            android:id="@+id/math_vetores_rn"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@android:color/transparent" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/linear1_1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\nAxiomas de Espaço Vetorial"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:text="Seja V um conjunto não vazio. Para ser um espaço vetorial, as seguintes propriedades devem ser satisfeitas:" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\nI. Em relação à Adição"
            android:textStyle="italic"
            android:textSize="16sp" />

        <WebView
            android:id="@+id/math_axiomas_adicao"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="@android:color/transparent" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/linear1_2" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\nII. Em relação ao Escalar"
            android:textStyle="italic"
            android:textSize="16sp" />

        <WebView
            android:id="@+id/math_axiomas_escalar"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="@android:color/transparent" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\nExemplo: O Espaço ℝ²"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#005088" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:justificationMode="inter_word"
            android:text="No ℝ², as operações usuais garantem a estrutura de espaço vetorial, onde a soma de pares ordenados e a multiplicação por real preservam as propriedades associativas e comutativas." />

        <View
            android:layout_width="match_parent"
            android:layout_height="80dp" />

    </LinearLayout>
</ScrollView>