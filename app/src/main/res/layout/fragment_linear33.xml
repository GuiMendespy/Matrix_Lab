<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.reflow.Linear33">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Operadores Diagonalizáveis"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#005088"
            android:paddingBottom="8dp" />

        <View
            android:layout_width="100dp"
            android:layout_height="3dp"
            android:background="#005088"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:justificationMode="inter_word"
            android:text="Dizemos que um operador linear T é diagonalizável se existe uma base de V composta exclusivamente por autovetores de T. Nessa base, a matriz do operador assume uma forma diagonal." />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:layout_marginTop="8dp"
            android:src="@drawable/exemplo45" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\nCritério de Diagonalização"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Um operador de ordem n é diagonalizável se, e somente se, ele possui n autovetores linearmente independentes (LI)." />

        <WebView
            android:id="@+id/math_def_diag"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@android:color/transparent" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Exemplo: Operador Não Diagonalizável"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#C62828"
            android:paddingTop="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:text="Nem todo operador é diagonalizável. Considere a matriz abaixo:" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/unidade3_35" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:background="#FDEAEA"
            android:padding="12dp"
            android:layout_marginTop="8dp"
            android:text="Neste exemplo, o polinômio característico possui raízes repetidas, mas não gera autovetores LI suficientes para formar uma base do ℝ³. Logo, T não pode ser diagonalizado." />

        <View
            android:layout_width="match_parent"
            android:layout_height="80dp" />

    </LinearLayout>
</ScrollView>