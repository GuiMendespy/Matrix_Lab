<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.reflow.Vetorial14">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Norma, Ângulo e Produto Interno"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:justificationMode="inter_word"
            android:text="Os números x e y são as componentes de v na base canônica. A primeira componente é chamada abscissa e a segunda a ordenada. Um vetor no plano é um par ordenado (x, y) de números reais, chamado de expressão analítica." />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\nMódulo de um vetor"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:justificationMode="inter_word"
            android:text="Seja o vetor v = (x, y). Pelo teorema de Pitágoras, a norma (ou módulo) é dada por:" />

        <WebView
            android:id="@+id/math_modulo"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@android:color/transparent" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/exemplo14" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\nProduto Escalar"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:justificationMode="inter_word"
            android:text="Chama-se produto escalar de dois vetores u e v ao número real obtido pela soma dos produtos de suas componentes correspondentes:" />

        <WebView
            android:id="@+id/math_prod_escalar"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@android:color/transparent" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/exemplo16" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\nDefinição Geométrica"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <WebView
            android:id="@+id/math_def_geometrica"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@android:color/transparent" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\nCálculo do ângulo entre dois vetores"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:justificationMode="inter_word"
            android:text="A partir da definição geométrica, podemos isolar o cosseno para encontrar o ângulo teta entre os vetores u e v não nulos:" />

        <WebView
            android:id="@+id/math_angulo_vetores"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@android:color/transparent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="80dp" />

    </LinearLayout>
</ScrollView>